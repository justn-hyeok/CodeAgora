{
  "name": "codeagora",
  "version": "1.0.0-rc.1",
  "type": "module",
  "description": "Multi-LLM code review pipeline — parallel reviewers, structured debate, consensus verdict",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justn-hyeok/CodeAgora.git"
  },
  "keywords": [
    "code-review",
    "llm",
    "multi-agent",
    "cli",
    "tui",
    "ai",
    "static-analysis"
  ],
  "files": [
    "src/dist/**/*.js",
    "src/dist/**/*.d.ts",
    "src/data/**",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "codeagora": "./src/dist/cli/index.js",
    "agora": "./src/dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
