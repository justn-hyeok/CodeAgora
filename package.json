    "@ai-sdk/groq": "^3.0.27",
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@clack/prompts": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.111",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "tsx": "^4.21.0",
    "vitest": "^1.2.0"
  }
