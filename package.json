{
  "name": "codeagora",
  "version": "2.0.0-rc.12",
  "type": "module",
  "description": "Multi-LLM code review pipeline — parallel reviewers, structured debate, consensus verdict",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bssm-oss/CodeAgora.git"
  },
  "homepage": "https://github.com/bssm-oss/CodeAgora#readme",
  "bugs": {
    "url": "https://github.com/bssm-oss/CodeAgora/issues"
  },
  "keywords": [
    "code-review",
    "llm",
    "multi-agent",
    "cli",
    "tui",
    "ai",
    "static-analysis"
  ],
  "files": [
    "packages/shared/dist/**/*.js",
    "packages/shared/dist/**/*.d.ts",
    "packages/core/dist/**/*.js",
    "packages/core/dist/**/*.d.ts",
    "packages/cli/dist/**/*.js",
    "packages/cli/dist/**/*.d.ts",
    "packages/github/dist/**/*.js",
    "packages/github/dist/**/*.d.ts",
    "packages/shared/src/data/**",
    "scripts/postinstall.cjs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "codeagora": "./packages/cli/dist/index.js",
    "agora": "./packages/cli/dist/index.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:web": "cd packages/web && vitest run",
    "test:all": "vitest run && cd packages/web && vitest run",
    "dev": "pnpm --filter @codeagora/cli dev"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.27",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@ai-sdk/fireworks": "^2.0.40",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/deepinfra": "^2.0.39",
    "@ai-sdk/moonshotai": "^2.0.10",
    "@ai-sdk/perplexity": "^3.0.23",
    "@ai-sdk/huggingface": "^1.0.37",
    "@ai-sdk/baseten": "^1.0.38",
    "@clack/prompts": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.111",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.5",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^1.2.0"
  }
}
